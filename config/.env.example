NODE_ENV=development
PORT=3000

# LLM
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=480000
OLLAMA_EMBED_TIMEOUT_MS=120000
OLLAMA_EMBED_RETRIES=2

# Vector DB (ChromaDB)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=harpia_docs
SCHEMA_SQL_PATH=./docs/schema.sql
RAG_ENABLE_TOKEN_GUARD=false
RAG_MAX_OUTPUT_TOKENS=220
RAG_KEEP_ALIVE=5m
RAG_NUM_CTX=2048
RAG_MAX_DOC_TOKENS=550
KNOWLEDGE_SCHEMA_MAX_COLUMNS=28
KNOWLEDGE_SCHEMA_MAX_RELATIONS=10

# Whisper
WHISPER_BIN_PATH=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-base.bin
WHISPER_LANGUAGE=pt

# Indexing
CHUNK_SIZE=800
CHUNK_OVERLAP=120

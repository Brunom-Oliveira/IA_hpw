NODE_ENV=development
PORT=8090

# LLM
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=granite4:3b
EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT_MS=180000
OLLAMA_EMBED_TIMEOUT_MS=120000
OLLAMA_EMBED_RETRIES=2

# Vector DB (Qdrant)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=harpia_docs
QDRANT_SCHEMA_COLLECTION=schema_documents
QDRANT_KNOWLEDGE_COLLECTION=knowledge_base
QDRANT_VECTOR_SIZE=768
SCHEMA_SQL_PATH=./docs/schema.sql

RAG_ENABLE_TOKEN_GUARD=false
RAG_MAX_OUTPUT_TOKENS=160
RAG_MAX_OUTPUT_TOKENS_LOOKUP=90
RAG_KEEP_ALIVE=5m
RAG_NUM_CTX=1024
RAG_TOPK_DEFAULT=2
RAG_TOPK_MAX=3
RAG_MIN_SCORE=0.15
RAG_CACHE_TTL_MS=900000
RAG_CACHE_MAX_ITEMS=300
RAG_ADMIN_TOKEN=
RAG_MAX_DOC_TOKENS=550
KNOWLEDGE_SCHEMA_MAX_COLUMNS=28
KNOWLEDGE_SCHEMA_MAX_RELATIONS=10
CHAT_STREAM_TIMEOUT_MS=600000

# Whisper
WHISPER_BIN_PATH=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=./models/ggml-medium.bin
WHISPER_LANGUAGE=pt
LD_LIBRARY_PATH=/opt/whisper.cpp/build/src:/opt/whisper.cpp/build/ggml/src:/opt/whisper.cpp/build/ggml/src/ggml-cpu

# Indexing
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MANUAL_UPLOAD_CHUNK_SIZE=2500
MANUAL_UPLOAD_CHUNK_OVERLAP=250
